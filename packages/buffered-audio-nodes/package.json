{
  "name": "@buffered-audio/nodes",
  "version": "0.22.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Matt Cavender",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/visionsofparadise/buffered-audio-graph",
    "directory": "packages/buffered-audio-nodes"
  },
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ../../agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\"",
    "check:verbose": "concurrently \"eslint .\" \"tsc --noEmit\"",
    "lint": "eslint . --fix --cache --format ../../agent-eslint.js",
    "lint:verbose": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsup",
    "docs": "tsx scripts/generate-docs.ts",
    "unit": "vitest run --project unit",
    "integration": "vitest run --project integration",
    "integration:heavy": "vitest run -c vitest.heavy.config.ts",
    "benchmark": "vitest run -c vitest.benchmark.config.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "concurrently": "*",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "*",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@buffered-audio/core": "0.10.0",
    "@buffered-audio/utils": "0.6.5",
    "bufferfy": "^4.0.3",
    "wavefile": "^11.0.0",
    "zod": "^4.3.6"
  }
}
